# 1. Base Model Selection
FROM gemma4:e2b

# 2. Hardware Allocation (Force 100% CPU Inference)
PARAMETER num_gpu 0

# 3. Memory & Context Window Configuration (128k Tokens)
PARAMETER num_ctx 16384

# 4. Standard Gemma 4 Production Sampling Presets
PARAMETER temperature 1.0
PARAMETER top_p 0.95
PARAMETER top_k 64
